apiVersion: monitoring.coreos.com/v1alpha1
kind: ScrapeConfig
metadata:
  name: laptop-host-scraper
  namespace: argocd                    # Lives alongside your core Prometheus controller
  labels:
    release: cluster-monitoring-app    # CRITICAL: Forces Prometheus to auto-discover this task
spec:
  staticConfigs:
    - targets:
        - 'kubernetes.default.svc:443' # Targets the master K3s host API server endpoints
  httpClientConfig:
    bearerTokenFile: /var/run/secrets/kubernetes.io/serviceaccount/token
    tlsConfig:
      caFile: /var/run/secrets/kubernetes.io/serviceaccount/ca.crt
      insecureSkipVerify: true
