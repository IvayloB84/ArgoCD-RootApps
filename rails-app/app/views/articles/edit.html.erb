<%# app/views/articles/edit.html.erb %>
<div class="max-w-2xl mx-auto my-12 p-8 bg-white border border-gray-200 rounded-2xl shadow-sm">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Modify Your Article</h1>

  <%# FIXED: Pulls in the updated _form partial structure dynamically %>
  <%= render "form", article: @article %>

  <div class="mt-6 pt-6 border-t border-gray-100 flex justify-between items-center text-sm">
    <%= link_to "← Cancel and Back", article_path(@article), class: "text-gray-500 hover:text-gray-700 font-medium" %>
    <%= link_to "Delete Article Permanently", article_path(@article), data: { turbo_method: :delete, turbo_confirm: "Are you absolutely sure?" }, class: "text-red-500 hover:text-red-700 font-medium" %>
  </div>
</div>