<%# app/views/articles/_form.html.erb %>
<%= form_with(model: article) do |form| %>
  <%# ... your fields (Title, Body) ... %>

  <div class="mb-6">
    <%= form.label :image, "Header Cover Photo", class: "block text-sm font-semibold text-gray-700 mb-2" %>
    
    <% if form.object.image.attached? %>
      <div class="flex items-center space-x-4 p-4 border border-gray-200 rounded-lg bg-gray-50 mb-3">
        <div class="w-16 h-16 rounded overflow-hidden shadow-sm bg-white">
          <%= image_tag form.object.image, class: "w-full h-full object-cover" %>
        </div>
        <div class="flex items-center space-x-2">
          <%= form.check_box :purge_image, class: "rounded border-gray-300 text-blue-600 focus:ring-blue-500 h-4 w-4 cursor-pointer" %>
          <%= form.label :purge_image, "Remove current image file completely", class: "text-sm text-red-600 font-medium cursor-pointer select-none" %>
        </div>
      </div>
    <% end %>

    <%= form.file_field :image, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 border border-gray-300 rounded-lg p-2 bg-white" %>
  </div>

  <%= form.submit class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-lg text-sm cursor-pointer shadow-sm w-full transition" %>
<% end %>