<%# app/views/articles/index.html.erb %>
<div class="max-w-4xl mx-auto px-4 py-8">
  <!-- Header Section -->
  <div class="flex justify-between items-center mb-8 pb-4 border-b border-gray-200">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Articles Feed V2</h1>
    <%= link_to "Write New Article", new_article_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors" %>
  </div>

  <!-- Feed Grid Layout -->
  <div id="articles" class="space-y-6">
    <% if @articles.any? %>
      <% @articles.each do |article| %>
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200 p-6 hover:shadow-md transition-shadow">
          <h2 class="text-2xl font-bold text-gray-900 mb-2"><%= article.title %></h2>
          <p class="text-gray-600 mb-4 line-clamp-3"><%= truncate(article.body, length: 150) %></p>
          <div class="flex justify-end">
            <%= link_to "Read Article →", article_path(article), class: "text-sm font-semibold text-blue-600 hover:text-blue-800 transition-colors" %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-12 bg-gray-50 rounded-lg border-2 border-dashed border-gray-300">
        <p class="text-gray-500 text-lg">No articles posted yet.</p>
      </div>
    <% end %>
  </div>
</div>