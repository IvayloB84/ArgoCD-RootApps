<%# app/views/articles/new.html.erb %>
<h1>Write New Article</h1>

<%= form_with model: @article, url: articles_path do |form| %>
  <% if @article.errors.any? %>
    <div style="color: red;">
      <h2><%= pluralize(@article.errors.count, "error") %> prohibited this article from being saved:</h2>
      <ul>
        <% @article.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title %><br>
    <%= form.text_field :title, style: "width: 100%; max-width: 400px; padding: 5px;" %>
  </div>

  <br>

  <div>
    <%= form.label :body %><br>
    <%= form.text_area :body, rows: 6, style: "width: 100%; max-width: 400px; padding: 5px;" %>
  </div>

  <br>

  <div>
    <%= form.submit "Publish Article" %>
  </div>
<% end %>

<br>
<%= link_to "Back to feed", articles_path %>