<%# app/views/products/new.html.erb %>
<h1>New Product</h1>

<%# FIXED: Added explicit '/rails' scope path matching your Traefik proxy rules %>
<%= form_with model: @product, url: "/rails/products" do |form| %>
  <div>
    <%= form.label :name %><br>
    <%= form.text_field :name %>
  </div>

  <br>

  <div>
    <%= form.submit "Create Product" %>
  </div>
<% end %>

<br>
<%= link_to "Back to products", "/rails/products" %>