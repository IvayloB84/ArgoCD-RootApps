<%# app/views/products/show.html.erb %>
<h1><%= @product.name %></h1>

<ul>
  <li><strong>Database ID:</strong> <%= @product.id %></li>
  <li><strong>Created At:</strong> <%= @product.created_at.strftime("%B %d, %Y at %H:%M") %></li>
</ul>

<br>
<div style="display: flex; gap: 10px; align-items: center;">
  <%= link_to "Edit this product", edit_product_path(@product) %> |
  
  <%# FIXED: Completely invisible button container that masquerades perfectly as a red link %>
  <%= button_to "Destroy this product", product_path(@product), method: :delete, form: { data: { confirm: "Are you sure?" } }, style: "background: none; border: none; color: red; text-decoration: underline; font-family: inherit; font-size: inherit; cursor: pointer; padding: 0; margin: 0;" %> |
  
  <%= link_to "Back to products", products_path %>
</div>