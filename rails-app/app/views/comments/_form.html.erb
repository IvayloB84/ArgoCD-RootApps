<%= form_with(model: [ @article, @article.comments.build ]) do |form| %>
  <% if flash[:alert] %>
    <!-- Existing validation alert banner block ... -->
  <% end %>

  <% # FIXED: Styled Name input field with custom validation guidelines %>
  <div class="mb-4">
    <%= form.label :commenter, "Your Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_field :commenter, placeholder: "e.g. John Doe", class: "block w-full border border-gray-300 rounded-lg p-2.5 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <div class="mb-4">
    <%= form.label :body, "Join the conversation", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= form.text_area :body, class: "block w-full border border-gray-300 rounded-lg p-2.5 bg-white text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500" %>
  </div>

  <%= form.submit "Post Comment", class: "bg-gray-900 text-white font-semibold py-2 px-4 rounded-lg hover:bg-gray-800 text-sm cursor-pointer" %>
<% end %>