<%# app/views/registrations/new.html.erb %>
<div class="min-h-[80vh] flex flex-col justify-center py-12 sm:px-6 lg:px-8 bg-gray-50">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="mt-6 text-center text-3xl font-extrabold text-gray-900 tracking-tight">
      Create your account
    </h2>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-8 px-4 shadow sm:rounded-xl sm:px-10 border border-gray-200">
      
      <% if @user.errors.any? %>
        <div class="mb-4 bg-red-50 border-l-4 border-red-500 p-3 rounded text-sm text-red-800">
          <p class="font-bold mb-1">Registration blocked:</p>
          <ul class="list-disc pl-4 text-xs space-y-0.5">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with model: @user, url: signup_path, class: "space-y-6" do |form| %>
        <div>
          <%= form.label :username, "Name (Username)", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.text_field :username, placeholder: "Min 3 characters", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white text-gray-900" %>
        </div>

        <!-- FIXED: Added required email field configuration -->
        <div>
          <%= form.label :email_address, "Email Address", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.email_field :email_address, placeholder: "you@example.com", required: true, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white text-gray-900" %>
        </div>


        <div>
          <%= form.label :password, "Password", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.password_field :password, placeholder: "Min 8 symbols", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white text-gray-900" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "Confirm Password", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.password_field :password_confirmation, placeholder: "Repeat password", class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white text-gray-900" %>
        </div>

        <div>
          <%= form.label :date_of_birth, "Date of Birth", class: "block text-sm font-semibold text-gray-700 mb-1" %>
          <%= form.date_field :date_of_birth, class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm bg-white text-gray-900" %>
        </div>

        <div>
          <%= form.submit "Register Account", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
        </div>
      <% end %>

        <div class="mt-6 pt-6 border-t border-gray-100 text-center text-sm text-gray-600">
        Already registered? 
        <%= link_to "Sign in here", new_session_path, class: "font-semibold text-blue-600 hover:text-blue-500 transition-colors ml-1" %>
      </div>

    </div>
  </div>
</div>