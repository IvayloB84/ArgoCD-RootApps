<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for?(:title) ? yield(:title) : "Rails App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">

    <%# FIXED: Standard stylesheet asset helper linking to your tailwind stream %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  </head>

  <body class="bg-gray-50 min-h-screen text-gray-900">
<nav class="bg-white border-b border-gray-200 py-4 px-6 mb-8 shadow-sm">
      <div class="max-w-5xl mx-auto flex justify-between items-center">
        <%= link_to "📰 My Rails Blog", articles_path, class: "font-bold text-lg text-gray-900 hover:text-blue-600 transition-colors" %>
        
        <div class="text-sm font-semibold">
          <% if authenticated? %>
            <span class="text-gray-600 mr-4">Welcome back!</span>
            <% # FIXED: Standardized link layout pathing utilizing your clean fallback parameters %>
            <%= link_to "Sign Out", signout_path, class: "text-red-500 hover:text-red-700 transition-colors" %>
          <% else %>
            <%= link_to "Sign In to Write", new_session_path, class: "text-blue-600 hover:text-blue-800 transition-colors bg-blue-50 py-1.5 px-4 rounded-md hover:bg-blue-100" %>
          <% end %>
        </div>
        
        </div>
      </div>
    </nav>
    <main>
      <%# FIXED: This injects your actual articles, forms, and pages back into the layout %>
      <%= yield %>
    </main>
  </body>
</html>