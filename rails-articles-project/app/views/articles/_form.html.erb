<%= form_with model: article, html: { multipart: true, class: "space-y-6" } do |form| %>

  <% if article.user_id == Current.user&.id || Current.user&.admin? %>
    <!-- Title Input -->
    <div class="mb-6">
      <%= form.label :title, "Article Title", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :title, class: "block w-full rounded-lg border border-gray-300 p-2.5 bg-white text-gray-900 focus:border-blue-500 focus:ring-blue-500 text-sm shadow-sm" %>
    </div>

    <!-- Body Input -->
    <div class="mb-6">
      <%= form.label :body, "Article Body", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :body, rows: 6, class: "block w-full rounded-lg border border-gray-300 p-2.5 bg-white text-gray-900 focus:border-blue-500 focus:ring-blue-500 text-sm shadow-sm" %>
    </div>
  <% else %>
    <div class="p-4 mb-6 text-sm text-blue-800 rounded-lg bg-blue-50 font-medium">
      💡 You are editing this article as an Administrator. You retain full control over the header media attachment layers below.
    </div>
  <% end %>

  <!-- IMAGE MEDIA MANAGEMENT LAYER -->
  <div class="mb-6 bg-gray-50 border border-gray-200 rounded-xl p-4">
    <%= form.label :image, "Header Cover Photo", class: "block text-sm font-bold text-gray-700 mb-2" %>
    
    <% if article.image.attached? && article.image.persisted? %>
      <!-- 📸 Visual verification thumbnail of the current image -->
      <div class="mb-4 flex items-center gap-4 bg-white p-3 border border-gray-200 rounded-lg shadow-sm max-w-md">
        <%= image_tag article.image.variant(resize_to_limit: [100, 100]), class: "rounded-md border border-gray-100 object-cover h-16 w-16" %>
        <div>
          <p class="text-xs font-semibold text-gray-500 mb-1">Current file attached</p>
          
          <!-- 🗑️ The structural checkbox that links to your controller's :purge_image key -->
          <label class="inline-flex items-center text-sm text-red-600 font-bold hover:text-red-800 cursor-pointer select-none">
            <%= form.check_box :purge_image, class: "rounded border-gray-300 text-red-600 focus:ring-red-500 mr-2 h-4 w-4 cursor-pointer" %>
            Remove Current Cover Image
          </label>
        </div>
      </div>
    <% end %>

    <!-- File Input to upload a fresh picture -->
    <p class="text-xs text-gray-500 mb-2 font-medium"><%= article.image.attached? ? "Or choose a new file to replace it:" : "Choose a image file to upload:" %></p>
    <%= form.file_field :image, class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100 border border-gray-300 rounded-lg p-2 bg-white" %>
  </div>

  <%= form.submit "Update Article", class: "bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 px-5 rounded-lg text-sm cursor-pointer shadow-sm w-full transition" %>
<% end %>