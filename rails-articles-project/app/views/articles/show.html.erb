<%# app/views/articles/show.html.erb %>
<div class="max-w-3xl mx-auto px-4 py-8">
  <!-- Navigation Top Bar -->
  <div class="mb-6">
    <%= link_to "← Back to Articles Feed", articles_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors" %>
  </div>

  <!-- Render cover photo banner elegantly at the top of the content stack -->
  <% if @article.image.attached? %>
    <div class="w-full mb-6 rounded-2xl overflow-hidden shadow-sm max-h-96 border border-gray-200">
      <%= image_tag @article.image, class: "w-full h-full object-cover" %>
    </div>
  <% end %>

  <!-- Main Article Body Container Wrapper -->
  <article class="bg-white shadow rounded-lg border border-gray-200 p-6 mb-8">
    
    <!-- FIXED: Pristine header spacing block grouping Title and Action links on a single line under all conditions -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-6 pb-4 border-b border-gray-100 gap-4">
      <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight"><%= @article.title %></h1>
      
      <!-- ARTICLE ACTION LINKS: Wrapped tightly and isolated to prevent parent flex collapse -->
      <div class="flex items-center text-sm font-semibold shrink-0">
          <% if authenticated? && (@article.user_id == Current.user.id || Current.user.admin?) %>
          <div class="flex items-center space-x-3">
            <%= link_to "Edit Article", edit_article_path(@article), class: "text-blue-600 hover:text-blue-800 transition-colors" %>
            <span class="text-gray-300">|</span>
            <%= button_to "Delete Article", article_path(@article), method: :delete, form: { onclick: "return confirm('Are you absolutely sure you want to delete this article and all of its comments permanently?');" }, class: "text-red-500 hover:text-red-700 hover:underline cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>
    
    <!-- Article Main Text Body Field -->
    <div class="prose max-w-none text-gray-700 text-lg leading-relaxed whitespace-pre-wrap">
      <%= @article.body %>
    </div>
  </article>

  <hr class="border-t border-gray-200 my-8">

  <!-- Flash alert validation banners render directly above the interaction zone -->
  <% if flash[:alert] %>
    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg mb-6 shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm font-semibold text-red-800">
            <%= flash[:alert] %>
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Active Dynamic Comments Feed Section -->
  <h2 class="text-2xl font-bold text-gray-900 mb-4">Comments (<%= @article.comments.count %>)</h2>
  <div id="comments" class="space-y-4 mb-8">
    <% if @article.comments.any? %>
      <% @article.comments.each do |comment| %>
        <% if comment.persisted? %>
          <div class="bg-white rounded-lg border border-gray-200 shadow-sm p-4 relative group">
            <div class="flex justify-between items-start mb-2">
              <p class="text-sm font-semibold text-gray-900">
                <span class="inline-block w-2 h-2 rounded-full bg-blue-500 mr-1.5"></span>
                <%= comment.commenter.presence || "Anonymous" %> 
                <span class="text-xs font-normal text-gray-400 ml-2">shared thoughts</span>
              </p>
              
              <!-- Clean Red Borderless Fallback Delete Link Button -->
              <% if authenticated? && @article.user_id == Current.user.id %>
                <%= button_to "Delete", [comment.article, comment], method: :delete, form: { data: { confirm: "Are you sure?" } }, class: "text-xs font-medium text-red-500 hover:text-red-700 hover:underline cursor-pointer opacity-80 group-hover:opacity-100 transition-opacity" %>
              <% end %>
            </div>
            <p class="text-gray-600 text-sm whitespace-pre-wrap pl-3 border-l-2 border-gray-100"><%= comment.body %></p>
          </div>
        <% end %>
      <% end %>
    <% else %>
      <p class="text-gray-400 italic py-2">No comments left yet. Be the first to share your thoughts below!</p>
    <% end %>
  </div>

  <!-- Interactive Input Form Sheet Container -->
  <div class="bg-gray-50 rounded-lg border border-gray-200 p-6">
    <h3 class="text-lg font-bold text-gray-900 mb-4">Leave a Comment</h3>
    
    <%= form_with model: [ @article, @article.comments.build ], class: "space-y-4" do |form| %>
      
      <% if authenticated? %>
        <% # FIXED: Automatically signs the comment with the logged-in user's name without showing an input box %>
        <%= form.hidden_field :commenter, value: Current.user.username %>
        <p class="text-sm font-medium text-gray-600 mb-2">
          Posting as: <span class="font-bold text-gray-900">👤 <%= Current.user.username %></span>
        </p>
      <% else %>
        <% # Fallback: Anonymous visitors are still asked to type a signature name %>
        <div>
          <%= form.label :commenter, "Your Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= form.text_field :commenter, placeholder: "Min 3 characters", class: "block w-full max-w-md rounded-md border border-gray-300 shadow-sm p-2 bg-white text-gray-900 focus:border-blue-500 focus:ring-blue-500 text-sm" %>
        </div>
      <% end %>

      <div>
        <%= form.label :body, "Comment Text", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_area :body, rows: 4, placeholder: "Type your comment here (minimum 10 characters)...", class: "block w-full max-w-xl rounded-md border border-gray-300 shadow-sm p-2 bg-white text-gray-900 focus:border-blue-500 focus:ring-blue-500 text-sm" %>
      </div>

      <div>
        <%= form.submit "Post Comment", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>

</div>