<%# app/views/articles/edit.html.erb %>
<div class="max-w-2xl mx-auto my-12 p-8 bg-white border border-gray-200 rounded-2xl shadow-sm">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Modify Your Article</h1>

  <%= render "form", article: @article %>

  <div class="mt-6 pt-6 border-t border-gray-100 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 text-sm">
    <%= link_to "← Cancel and Back", article_path(@article), class: "text-gray-500 hover:text-gray-700 font-medium transition-colors" %>
    
    <% # FIXED: Converted to button_to with a native browser onclick confirmation box to prevent Turbo method drops %>
    <%= button_to "Delete Article Permanently", article_path(@article), method: :delete, form: { onclick: "return confirm('Are you absolutely sure you want to delete this article and all of its comments permanently?');", class: "inline-block" }, class: "text-red-500 hover:text-red-700 font-medium transition-colors cursor-pointer hover:underline" %>
  </div>
</div>